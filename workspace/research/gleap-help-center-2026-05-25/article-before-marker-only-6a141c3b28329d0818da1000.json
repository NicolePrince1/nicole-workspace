{
  "title": {
    "en": "Create your first client report"
  },
  "description": {
    "en": "A beginner-friendly flow for creating a report."
  },
  "content": {
    "en": {
      "type": "doc",
      "content": [
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "To create your first useful report, work in this order."
            }
          ]
        },
        {
          "type": "bulletList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Open Clients and add the client you want to report on."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Connect at least one data source for that client."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Open the client and create a new project. Choose Report if you want a paged client-ready report."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Start from a template or a blank report."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Add widgets and choose the right data source for each widget."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Preview the report and check the date range."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Share the report link or schedule delivery."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "Tip: build the report with one client and one data source first. Once that works, add more pages, widgets, and integrations."
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 2,
            "dataSource": "nicole-marker-only-screenshot-pass"
          },
          "content": [
            {
              "type": "text",
              "text": "Start from the Clients screen"
            }
          ]
        },
        {
          "type": "paragraph",
          "attrs": {
            "dataSource": "nicole-marker-only-screenshot-pass"
          },
          "content": [
            {
              "type": "text",
              "text": "Your first report starts by adding or opening the client you want to report on."
            }
          ]
        },
        {
          "type": "image",
          "attrs": {
            "src": "https://raw.githubusercontent.com/NicolePrince1/nicole-workspace/3ad202b/workspace/tools/oviond-screenshot-studio/outputs/help-center-rollout/clients-home-markers-safe.png",

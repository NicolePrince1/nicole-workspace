            "textAlign": null
          },
          "content": [
            {
              "type": "text",
              "text": "Use this checklist when you are setting up Oviond for the first time."
            }
          ]
        },
        {
          "type": "bulletList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "attrs": {
                    "id": "e270e4ca-8a34-41cb-8be5-b240f465fe31",
                    "textAlign": null
                  },
                  "content": [
                    {
                      "type": "text",
                      "text": "Create or join your agency account."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "attrs": {
                    "id": "2581ab6a-b348-49f3-976a-e3ec0b1bc274",
                    "textAlign": null
                  },
                  "content": [
                    {
                      "type": "text",
                      "text": "Add your first client."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "attrs": {
                    "id": "a20edd7e-a245-412b-9c7f-ab6fb2bf81b1",
                    "textAlign": null
                  },
                  "content": [
                    {
                      "type": "text",
                      "text": "Connect at least one data source for that client."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "attrs": {
                    "id": "2e88707e-b89f-4721-825d-faa219b44a42",
                    "textAlign": null
                  },
                  "content": [
                    {
                      "type": "text",
                      "text": "Create a report or dashboard."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "attrs": {
                    "id": "9c64e410-6ceb-4d0f-bc35-b25d50651557",
                    "textAlign": null
                  },
                  "content": [
                    {
                      "type": "text",
                      "text": "Add widgets that use the connected data source."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "attrs": {
                    "id": "3faa64e8-7fdf-42f3-ba10-e836120e381c",
                    "textAlign": null
                  },
                  "content": [
                    {
                      "type": "text",
                      "text": "Share the report with your client or test an automation."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "paragraph",
          "attrs": {
            "id": "3435bc15-cccd-4aa4-962c-deb5e6998b4c",
            "textAlign": null
          },
          "content": [
            {
              "type": "text",
              "text": "If you get stuck, start by checking whether the client has a connected data source and whether the widget date range contains data."
            }
          ]
        },
        {

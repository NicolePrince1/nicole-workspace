{
  "meta": {
    "lastTouchedVersion": "2026.5.2",
    "lastTouchedAt": "2026-05-05T06:02:51.154Z"
  },
  "wizard": {
    "lastRunAt": "2026-04-08T11:16:45.720Z",
    "lastRunVersion": "2026.4.8",
    "lastRunCommand": "doctor",
    "lastRunMode": "local"
  },
  "auth": {
    "profiles": {
      "openai-codex:codex-cli": {
        "provider": "openai-codex",
        "mode": "oauth"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-codex/gpt-5.5"
      },
      "models": {
        "openai/gpt-5.1-codex": {
          "alias": "GPT"
        },
        "openai-codex/gpt-5.4": {},
        "google/gemini-3.1-flash-lite-preview": {
          "alias": "gemini-flash-lite"
        },
        "openai-codex/gpt-5.5": {},
        "anthropic/claude-opus-4-6": {
          "alias": "opus"
        }
      },
      "workspace": "/data/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "tools": {
    "profile": "full",
    "exec": {
      "security": "full",
      "strictInlineEval": false
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions",
    "tts": {
      "provider": "openai",
      "providers": {
        "openai": {
          "voice": "coral",
          "speed": 1.25
        }
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "bootstrap-extra-files": {
          "enabled": true,
          "paths": [
            "hooks/bootstrap/AGENTS.md",
            "hooks/bootstrap/TOOLS.md"
          ]
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "streaming": {
        "mode": "partial"
      }
    },
    "slack": {
      "mode": "socket",
      "webhookPath": "/slack/events",
      "enabled": true,
      "userTokenReadOnly": true,
      "groupPolicy": "allowlist",
      "streaming": {
        "mode": "partial",
        "nativeTransport": true
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "controlUi": {
      "allowedOrigins": [
        "https://openclaw-railway-template-production-3ee7.up.railway.app"
      ]
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "trustedProxies": [
      "127.0.0.1"
    ],
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  },
  "plugins": {
    "allow": [
      "telegram",
      "usage-tracker",
      "slack",
      "openai",
      "anthropic",
      "google",
      "memory-core"
    ],
    "load": {
      "paths": [
        "/app/node_modules/@chrysb/alphaclaw/lib/plugin/usage-tracker"
      ]
    },
    "entries": {
      "telegram": {
        "enabled": true,
        "config": {}
      },
      "usage-tracker": {
        "enabled": true,
        "config": {},
        "hooks": {
          "allowConversationAccess": true
        }
      },
      "openai": {
        "enabled": true
      },
      "anthropic": {
        "enabled": true
      },
      "google": {
        "enabled": true
      },
      "memory-core": {
        "config": {
          "dreaming": {
            "enabled": true,
            "storage": {
              "mode": "separate"
            }
          }
        },
        "enabled": true
      }
    }
  }
}

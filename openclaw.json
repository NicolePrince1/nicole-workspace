{
  "meta": {
    "lastTouchedVersion": "2026.3.7",
    "lastTouchedAt": "2026-03-09T05:49:13.372Z"
  },
  "wizard": {
    "lastRunAt": "2026-03-09T05:49:11.134Z",
    "lastRunVersion": "2026.3.7",
    "lastRunCommand": "onboard",
    "lastRunMode": "local"
  },
  "auth": {
    "profiles": {
      "openai:default": {
        "provider": "openai",
        "mode": "api_key"
      },
      "openai-codex:codex-cli": {
        "provider": "openai-codex",
        "mode": "oauth"
      },
      "google:default": {
        "provider": "google",
        "mode": "api_key"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-codex/gpt-5.3-codex"
      },
      "models": {
        "openai/gpt-5.1-codex": {
          "alias": "GPT"
        },
        "openai-codex/gpt-5.3-codex": {}
      },
      "workspace": "/data/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "tools": {
    "profile": "full"
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist"
    }
  },
  "plugins": {
    "allow": [
      "telegram",
      "usage-tracker"
    ],
    "load": {
      "paths": [
        "/app/node_modules/@chrysb/alphaclaw/lib/plugin/usage-tracker"
      ]
    },
    "entries": {
      "telegram": {
        "enabled": true
      },
      "usage-tracker": {
        "enabled": true
      }
    }
  },
  "hooks": {
    "internal": {
      "entries": {
        "bootstrap-extra-files": {
          "enabled": true,
          "paths": [
            "hooks/bootstrap/AGENTS.md",
            "hooks/bootstrap/TOOLS.md"
          ]
        }
      },
      "enabled": true
    }
  }
}
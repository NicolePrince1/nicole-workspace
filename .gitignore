# Ignore everything by default.
*

# Whitelist specific files/dirs.
!workspace/
!workspace/**
workspace/.openclaw/
workspace/.openclaw/**
workspace/.trash/
workspace/.trash/**
workspace/tmp/
workspace/tmp/**
workspace/.tmp_*
workspace/dist/*.skill
workspace/memory/.trash/
workspace/memory/.trash/**
workspace/memory/.dreams/
workspace/memory/.dreams/**
workspace/**/__pycache__/
workspace/**/*.pyc
!gogcli/
gogcli/*
!gogcli/state.json
db/
db/**
!skills/
!skills/**
skills/**/__pycache__/
skills/**/*.pyc
!hooks/
!hooks/transforms/
!hooks/transforms/**
!cron/
!cron/jobs.json
!openclaw.json
!.gitignore
secrets/
# OpenClaw cron runtime state (local only; job definitions stay in cron/jobs.json)
cron/jobs-state.json
migration.log*
migration_full.log*
memory/dreaming/
DREAMS.md
research/competitor-intelligence/tmp-image-view.html
tools/oviond-screenshot-studio/outputs/help-center-rollout/raw/

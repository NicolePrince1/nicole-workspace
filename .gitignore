# Ignore everything by default.
*

# Whitelist specific files/dirs.
!workspace/
!workspace/**
workspace/.openclaw/
workspace/.openclaw/**
workspace/.trash/
workspace/.trash/**
workspace/tmp/
workspace/tmp/**
workspace/dist/*.skill
workspace/memory/.trash/
workspace/memory/.trash/**
workspace/memory/.dreams/
workspace/memory/.dreams/**
workspace/**/__pycache__/
workspace/**/*.pyc
!gogcli/
gogcli/*
!gogcli/state.json
db/
db/**
!skills/
!skills/**
skills/**/__pycache__/
skills/**/*.pyc
!hooks/
!hooks/transforms/
!hooks/transforms/**
!cron/
!cron/jobs.json
!openclaw.json
!.gitignore
secrets/
